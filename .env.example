# Required for CI/CD `wrangler deploy` (set as GitHub Actions secrets).
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Optional mobile API override. Defaults to https://breview.ing in code.
EXPO_PUBLIC_API_BASE_URL=https://breview.ing

# R2 image storage uses wrangler binding:
# IMAGES_BUCKET -> sahti-as-a-service-images (configured in wrangler.jsonc)
