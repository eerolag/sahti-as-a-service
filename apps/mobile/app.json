{
  "expo": {
    "name": "Breview",
    "slug": "breview",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/breview-logo.png",
    "scheme": "breview",
    "userInterfaceStyle": "dark",
    "ios": {
      "bundleIdentifier": "ing.breview.app",
      "icon": "./assets/images/breview-logo.png",
      "associatedDomains": [
        "applinks:breview.ing"
      ]
    },
    "android": {
      "package": "ing.breview.app",
      "adaptiveIcon": {
        "backgroundColor": "#020617",
        "foregroundImage": "./assets/images/breview-logo.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "breview.ing",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#020617",
          "android": {
            "image": "./assets/images/breview-logo.png",
            "imageWidth": 96
          }
        }
      ],
      "expo-font",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Breview käyttää kameraa juomakuvien lisäämiseen sessioihin.",
          "photosPermission": "Breview käyttää kuvia juomakuvien lisäämiseen sessioihin."
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
