{
  "expo": {
    "name": "Breview",
    "slug": "breview",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/breview-logo.png",
    "scheme": "breview",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "ing.breview.app",
      "icon": "./assets/images/breview-logo.png"
    },
    "android": {
      "package": "ing.breview.app",
      "adaptiveIcon": {
        "backgroundColor": "#020617",
        "foregroundImage": "./assets/images/breview-logo.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#020617",
          "android": {
            "image": "./assets/images/breview-logo.png",
            "imageWidth": 96
          }
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
