{
  "name": "breview",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "lightningcss": "1.30.1",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "scripts": {
    "dev:web": "npm --workspace @breview/web run dev",
    "dev:api": "npm --workspace @breview/api run dev",
    "dev:worker": "npm run dev:api",
    "dev:mobile": "npm --workspace @breview/mobile run start",
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:worker\"",
    "build:web": "npm --workspace @breview/web run build",
    "build": "npm run build:web && npm run typecheck",
    "deploy:worker": "npm run build:web && npm --workspace @breview/api run deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit && npm --workspace @breview/shared run typecheck && npm --workspace @breview/api-client run typecheck && npm --workspace @breview/web run typecheck && npm --workspace @breview/api run typecheck && npm --workspace @breview/mobile run typecheck"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260226.0",
    "@types/node": "^22.10.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.11",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.8",
    "wrangler": "^4.69.0"
  }
}
